<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/packSelectionFragment">

    <fragment
        android:id="@+id/packSelectionFragment"
        android:name="com.findwords.app.ui.PackSelectionFragment"
        android:label="@string/packs"
        tools:layout="@layout/fragment_pack_selection">
        <action
            android:id="@+id/action_packSelection_to_levelSelection"
            app:destination="@id/levelSelectionFragment" />
    </fragment>

    <fragment
        android:id="@+id/levelSelectionFragment"
        android:name="com.findwords.app.ui.LevelSelectionFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_level_selection">
        <argument
            android:name="packId"
            app:argType="integer" />
        <action
            android:id="@+id/action_levelSelection_to_game"
            app:destination="@id/gameFragment" />
    </fragment>

    <fragment
        android:id="@+id/gameFragment"
        android:name="com.findwords.app.ui.GameFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_game">
        <argument
            android:name="levelId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.findwords.app.ui.SettingsFragment"
        android:label="@string/settings"
        tools:layout="@layout/fragment_settings" />

</navigation>